<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Splash theme only. The app's actual visual identity lives in Compose
        (see com.ultraprocessed.theme.UltraprocessedTheme).
    -->
    <style name="Theme.Ultraprocessed.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_bg</item>
        <item name="postSplashScreenTheme">@style/Theme.Ultraprocessed</item>
    </style>

    <style name="Theme.Ultraprocessed" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/splash_bg</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
