<?xml version="1.0" encoding="utf-8"?>
<!--
    Foreground for the adaptive launcher icon: four vertical bars of
    varying heights, evoking a barcode without literally being one.
    Sits on the inner 72dp safe area within the 108dp icon canvas.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Bar 1 -->
    <path
        android:fillColor="#C7F25C"
        android:pathData="M40,38 h6 v32 h-6 z" />

    <!-- Bar 2 (taller) -->
    <path
        android:fillColor="#C7F25C"
        android:pathData="M50,30 h6 v48 h-6 z" />

    <!-- Bar 3 (medium) -->
    <path
        android:fillColor="#C7F25C"
        android:pathData="M60,42 h6 v24 h-6 z" />

    <!-- Bar 4 (tall again) -->
    <path
        android:fillColor="#C7F25C"
        android:pathData="M70,34 h6 v40 h-6 z" />
</vector>
