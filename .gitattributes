* text=auto eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.jar binary
*.aar binary
*.apk binary
*.aab binary
*.keystore binary
*.jks binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary

# Shell scripts always LF
*.sh   text eol=lf
gradlew text eol=lf

# Windows scripts always CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf
gradlew.bat text eol=crlf
