# Copy this to deploy/.env and fill in the values.
# Used by docker-compose at runtime. Never commit deploy/.env.

# Required: HMAC secret for device tokens. Generate one with:
#   openssl rand -hex 32
ULTRAPROCESSED_TOKEN_SECRET=change-me-please

# Optional: which port the backend listens on (default 8000).
# Cloudflare tunnel typically points at this.
ULTRAPROCESSED_PORT=8000

# Optional: SQLite default. Switch to Postgres when self-hosting at scale:
# ULTRAPROCESSED_DATABASE_URL=postgresql+psycopg://user:pass@db:5432/ultraprocessed
ULTRAPROCESSED_DATABASE_URL=sqlite:////app/data/ultraprocessed.db

# Optional: backend-side LLM relay. When set, phones can route their
# analyzer calls through the backend instead of holding API keys
# themselves. Leave blank to disable relay.
# ULTRAPROCESSED_RELAY_ANTHROPIC_API_KEY=sk-ant-...
# ULTRAPROCESSED_RELAY_OPENAI_COMPATIBLE_API_KEY=sk-...
# ULTRAPROCESSED_RELAY_OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1
